# ---------- Database ----------
POSTGRES_USER=crss_user
POSTGRES_PASSWORD=crss_password
POSTGRES_DB=crss_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://crss_user:crss_password@db:5432/crss_db

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- JWT ----------
SECRET_KEY=change-this-super-secret-key-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Google Sign-In ----
# Create at https://console.cloud.google.com/apis/credentials
# -> Create Credentials -> OAuth client ID -> Application type: Web application
# -> Authorized JavaScript origins: http://localhost:5173 (and your real domain later)
# No client secret needed -- this project uses the Google Identity Services "ID token"
# flow, verified server-side, not the server-side OAuth code exchange flow.
GOOGLE_CLIENT_ID=

# ---------- App ----------
PROJECT_NAME=Campus Resource Sharing System
ENVIRONMENT=development
DEBUG=true
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
API_V1_PREFIX=/api/v1

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@crss.edu
SMTP_TLS=true

# ---------- Uploads ----------
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Same Google OAuth Client ID as GOOGLE_CLIENT_ID above -- this one is safe to expose
# in the compiled frontend JS; Client IDs are public by design (unlike client secrets,
# which this flow never uses).
VITE_GOOGLE_CLIENT_ID=

# Used only by docker-compose.prod.yml at build time (Oracle Cloud / any VPS deploy).
# Set this to http://<your-vm-public-ip>:8000/api/v1, or https://yourdomain.com/api/v1
# if you've set up Nginx + a domain. Vite bakes this into the compiled JS at build
# time, so if you change it, you must rebuild the frontend image, not just restart it.
PUBLIC_API_URL=http://CHANGE_ME_TO_YOUR_VM_IP:8000/api/v1
