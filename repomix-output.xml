              <p className="text-xs text-ink-500 uppercase tracking-wide font-semibold mt-1">Borrower Rating</p>
            </div>
            <div>
              <p className="text-2xl font-bold text-ink-900">{stats.returned_on_time} / {stats.total_borrows}</p>
