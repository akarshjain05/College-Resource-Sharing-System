                    <span className="font-semibold text-ink-900">{r.reviewer_name}</span>
                    <span className="text-xs px-2 py-0.5 rounded-full bg-ink-100 text-ink-600">
                      To {profile.full_name.split(" ")[0]} as a {r.role}
