        </div>
      </div>

      {/* 4. MAIN SPLIT GRID (Nearby Items vs Rightbar) */}
      <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        {/* Left Side: Items Grid (8 Columns) */}
