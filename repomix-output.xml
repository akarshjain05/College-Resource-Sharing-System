          average_rating: found.average_rating,
          reviews_count: found.reviews_count,
          total_borrows: found.reviews_count * 3,
          category: { id: "cat-1", name: found.category },
          owner: { id: "owner-1", full_name: found.owner, trust_score: 95 },
