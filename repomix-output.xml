                owner_id=user_objs[r["owner"]].id,
                category_id=category_objs[r["category"]].id,
            )
            db.add(resource)

        db.commit()
        print("Seed data created successfully.")
        print("Admin login: admin@crss.edu / AdminPass123!")
        print("Student login: asha.rao@crss.edu / Password123!")
    finally:
