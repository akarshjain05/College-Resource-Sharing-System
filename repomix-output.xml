                  >
                    <option value="" className="text-slate-400">Select a category</option>
                    {categories.map((c) => (
                      <option key={c.id} value={c.id} className="text-slate-850 dark:text-slate-100 bg-white dark:bg-slate-950">
                        {c.name}
